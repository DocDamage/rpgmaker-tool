{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybridtile.studio/schemas/HybridCompatibilityProfile.schema.json",
  "title": "Hybrid Tile Studio Compatibility Profile",
  "type": "object",
  "required": [
    "format",
    "version",
    "id",
    "name",
    "signatures"
  ],
  "properties": {
    "format": {
      "const": "HybridCompatibilityProfile"
    },
    "version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guidance": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ]
    }
  },
  "additionalProperties": true
}
