{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybridtile.local/schemas/HybridCutsceneTimeline.schema.json",
  "title": "Hybrid Cutscene Timeline",
  "type": "object",
  "required": [
    "id",
    "format",
    "version",
    "cues",
    "duration"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "format": {
      "const": "HybridCutsceneTimeline"
    },
    "version": {
      "const": 1
    },
    "name": {
      "type": "string"
    },
    "duration": {
      "type": "number",
      "minimum": 0
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "cues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "at",
          "track",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "at": {
            "type": "number",
            "minimum": 0
          },
          "duration": {
            "type": "number",
            "minimum": 0
          },
          "track": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
