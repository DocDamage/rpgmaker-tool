{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybridtile.studio/schemas/HybridPlaytestJourney.schema.json",
  "title": "Hybrid Tile Studio Player Journey",
  "type": "object",
  "required": [
    "format",
    "version",
    "id",
    "name",
    "steps",
    "assertions"
  ],
  "properties": {
    "format": {
      "enum": [
        "HybridPlaytestJourney",
        "HybridPlaytestScenario"
      ]
    },
    "version": {
      "enum": [
        1,
        2
      ]
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "studioVersion": {
      "type": "string"
    },
    "setup": {
      "$ref": "#/$defs/state"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "assertions": {
      "$ref": "#/$defs/state"
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "properties": {
        "mapId": {
          "type": "integer",
          "minimum": 0
        },
        "player": {
          "type": [
            "object",
            "null"
          ]
        },
        "switches": {
          "type": "object"
        },
        "variables": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "step": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "move",
            "interaction",
            "transfer",
            "choice",
            "switch",
            "variable",
            "wait",
            "waitUntil",
            "recipe",
            "assert",
            "eventCommand"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
