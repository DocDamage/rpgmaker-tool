{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybridtile.local/schemas/HybridContentLibrary.schema.json",
  "title": "Hybrid Content Library",
  "type": "object",
  "required": [
    "format",
    "version",
    "items"
  ],
  "properties": {
    "format": {
      "const": "HybridContentLibrary"
    },
    "version": {
      "enum": [
        1,
        2
      ]
    },
    "exportedAt": {
      "type": "string"
    },
    "studioVersion": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "version",
          "payload"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "enum": [
              "map",
              "room",
              "event",
              "recipe",
              "quest",
              "encounter",
              "tileset",
              "map-fragment"
            ]
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "favorite": {
            "type": "boolean"
          },
          "contentHash": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
